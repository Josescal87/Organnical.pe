{
  "buildCommand": "npm test && next build",
  "rewrites": [
    { "source": "/", "destination": "/landing.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/reminders?secret=$CRON_SECRET",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/admin/cron/cleanup-pendientes",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/admin/cron/retry-boletas",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/blog-publish-notify?secret=$CRON_SECRET",
      "schedule": "0 10 * * *"
    }
  ]
}
