{
  "buildCommand": "npm test && next build",
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "sami.organnical.pe" }],
      "destination": "/$1"
    },
    { "source": "/", "destination": "/landing.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/reminders?secret=$CRON_SECRET",
      "schedule": "0 14 * * *"
    }
  ]
}
